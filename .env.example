# --- Vercel Postgres ---
# Create in Vercel dashboard: Project -> Storage -> Create Database -> Postgres.
# Vercel injects these automatically once connected to the project; for local
# dev, copy them from Project Settings -> Environment Variables.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# --- Vercel Blob (photo storage) ---
# Create in Vercel dashboard: Project -> Storage -> Create Database -> Blob.
BLOB_READ_WRITE_TOKEN=

# --- Resend (transactional email) ---
# Create a free account at https://resend.com, generate an API key.
RESEND_API_KEY=

# Email address that receives new lead / booking request notifications.
NOTIFY_EMAIL=loneoakhico@yahoo.com

# The "from" address Resend sends as. Until you verify a domain in Resend,
# use their shared test sender: onboarding@resend.dev
EMAIL_FROM=onboarding@resend.dev
